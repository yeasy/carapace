{
  "name": "@carapace/adapter-openclaw",
  "version": "0.8.0",
  "description": "OpenClaw plugin adapter for Carapace runtime security monitor.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tailer": {
      "import": "./dist/tailer.js",
      "types": "./dist/tailer.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "keywords": ["carapace", "openclaw", "security", "plugin"],
  "author": "Albert Yang",
  "license": "MIT",
  "dependencies": {
    "@carapace/core": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  }
}
