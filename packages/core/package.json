{
  "name": "@carapace/core",
  "version": "0.10.0",
  "description": "Core rule engine, event processing, and alerting for Carapace — AI agent runtime security.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./rules": {
      "import": "./dist/rules/index.js",
      "types": "./dist/rules/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "carapace",
    "security",
    "ai-agent",
    "runtime-monitor"
  ],
  "author": "Albert Yang",
  "license": "MIT",
  "optionalDependencies": {
    "better-sqlite3": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
