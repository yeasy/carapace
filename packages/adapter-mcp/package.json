{
  "name": "@carapace/adapter-mcp",
  "version": "0.6.0",
  "description": "MCP (Model Context Protocol) proxy adapter for Carapace runtime security monitor.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
