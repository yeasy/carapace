{
  "name": "@carapace/dashboard",
  "version": "0.10.2",
  "description": "Web dashboard for Carapace runtime security monitoring — real-time events, stats, and team policy management.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "carapace",
    "dashboard",
    "security",
    "monitoring",
    "siem"
  ],
  "author": "Albert Yang",
  "license": "MIT",
  "dependencies": {
    "@carapace/core": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
